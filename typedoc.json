{
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "exclude": ["**/*.test.ts", "**/__mocks__/**", "**/test-helpers.ts"],
  "externalSymbolLinkMappings": {
    "obsidian": {
      "addIcon": "#",
      "Workspace.updateOptions": "#",
      "MarkdownView": "#",
      "App.secretStorage": "#"
    },
    "typescript": {
      "setInterval": "#",
      "window.setInterval": "#"
    }
  },
  "disableSources": true,
  "excludePrivate": false,
  "excludeInternal": false,
  "tsconfig": "./tsconfig.json"
}
