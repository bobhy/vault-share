{
	"name": "vault-sync",
	"version": "0.1.0",
	"description": "Share Obsidian vaults between devices and users by syncing through Google Drive.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"setup:e2e:wdio": "node --import jiti/register tests/wdio/setup-wdio-token.ts",
		"test:e2e:single": "npm run build && wdio run wdio.conf.mts",
		"test:e2e:cross": "npm run build && wdio run wdio.multiremote.conf.mts",
		"docs": "typedoc && npm run docs --prefix google-auth-relay/worker",
		"new-credential": "node new-credential.mjs",
		"deploy": "node deploy.mjs",
		"playground:googleDrive:read": "vitest run --config vitest.playground.config.ts tests/playground/gdrive-read.playground.ts",
		"playground:googleDrive:write": "vitest run --config vitest.playground.config.ts tests/playground/gdrive-write.playground.ts"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.30.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.6.0",
		"@wdio/cli": "^9.27.0",
		"@wdio/globals": "^9.27.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"esbuild": "^0.28.0",
		"eslint-plugin-obsidianmd": "^0.2.8",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.5.0",
		"jiti": "^2.6.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"typedoc": "^0.28.0",
		"vitest": "^4.0.18",
		"wdio-obsidian-service": "^3.0.2"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
